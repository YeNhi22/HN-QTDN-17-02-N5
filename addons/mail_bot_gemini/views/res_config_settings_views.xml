<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_gemini" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.gemini</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="OdooBot Gemini AI" string="OdooBot Gemini AI" data-key="mail_bot_gemini">
                    <h2>OdooBot Gemini AI</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Gemini API Key</span>
                                <div class="text-muted">
                                    Lấy API key miễn phí tại
                                    <a href="https://aistudio.google.com/app/apikey" target="_blank">
                                        Google AI Studio
                                    </a>
                                </div>
                                <div class="content-group mt8">
                                    <field name="gemini_api_key"
                                           password="True"
                                           placeholder="AIza..."/>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Gemini Model</span>
                                <div class="text-muted">
                                    Model AI sử dụng (gemini-1.5-flash là nhanh và miễn phí)
                                </div>
                                <div class="content-group mt8">
                                    <field name="gemini_model"
                                           placeholder="gemini-1.5-flash"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">System Prompt (tùy chỉnh)</span>
                                <div class="text-muted">
                                    Hướng dẫn cho bot về cách trả lời. Để trống để dùng mặc định.
                                </div>
                                <div class="content-group mt8">
                                    <field name="gemini_system_prompt"
                                           placeholder="Bạn là OdooBot, trợ lý AI của hệ thống Odoo..."/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
