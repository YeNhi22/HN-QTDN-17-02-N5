<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Access rights cho OCR models — load sau khi models đã được tạo -->
        <record id="access_invoice_ocr_result_user" model="ir.model.access">
            <field name="name">invoice.ocr.result.user</field>
            <field name="model_id" ref="model_invoice_ocr_result"/>
            <field name="group_id" ref="base.group_user"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>
        <record id="access_invoice_ocr_result_admin" model="ir.model.access">
            <field name="name">invoice.ocr.result.admin</field>
            <field name="model_id" ref="model_invoice_ocr_result"/>
            <field name="group_id" ref="base.group_system"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
        <record id="access_invoice_ocr_wizard_user" model="ir.model.access">
            <field name="name">invoice.ocr.wizard.user</field>
            <field name="model_id" ref="model_invoice_ocr_wizard"/>
            <field name="group_id" ref="base.group_user"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
