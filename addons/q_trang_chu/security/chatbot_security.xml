<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="chatbot_conversation_rule_user" model="ir.rule">
            <field name="name">Chatbot: cuộc hội thoại của chính mình</field>
            <field name="model_id" ref="model_chatbot_conversation"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="chatbot_message_rule_user" model="ir.rule">
            <field name="name">Chatbot: tin nhắn của chính mình</field>
            <field name="model_id" ref="model_chatbot_message"/>
            <field name="domain_force">[('conversation_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
