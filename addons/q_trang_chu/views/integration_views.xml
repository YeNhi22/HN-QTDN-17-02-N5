<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- OCR Wizard -->
    <record id="view_invoice_ocr_wizard_form" model="ir.ui.view">
        <field name="name">invoice.ocr.wizard.form</field>
        <field name="model">invoice.ocr.wizard</field>
        <field name="arch" type="xml">
            <form string="📷 Scan hóa đơn">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        <strong>📸 Hướng dẫn:</strong>
                        Tải lên ảnh hóa đơn (JPG/PNG) rồi nhấn <b>Phân tích ngay</b>.
                        Hệ thống sẽ tự động đọc và trích xuất thông tin hóa đơn.
                    </div>
                    <group>
                        <field name="file_data" string="Ảnh hóa đơn (JPG/PNG)"
                               filename="file_name" widget="binary"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_process_ocr"
                            string="🔍 Phân tích ngay"
                            type="object"
                            class="btn-primary"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_invoice_ocr_wizard" model="ir.actions.act_window">
        <field name="name">Scan hóa đơn</field>
        <field name="res_model">invoice.ocr.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- OCR Result List -->
    <record id="view_invoice_ocr_result_tree" model="ir.ui.view">
        <field name="name">invoice.ocr.result.tree</field>
        <field name="model">invoice.ocr.result</field>
        <field name="arch" type="xml">
            <tree string="Kết quả OCR">
                <field name="create_date" string="Thời gian"/>
                <field name="name" string="File"/>
                <field name="nha_cung_cap" string="Nhà cung cấp"/>
                <field name="so_hoa_don" string="Số hóa đơn"/>
                <field name="tong_tien" string="Tổng tiền"/>
                <field name="state" string="Trạng thái"/>
            </tree>
        </field>
    </record>

    <!-- OCR Result Form -->
    <record id="view_invoice_ocr_result_form" model="ir.ui.view">
        <field name="name">invoice.ocr.result.form</field>
        <field name="model">invoice.ocr.result</field>
        <field name="arch" type="xml">
            <form string="Kết quả OCR hóa đơn">
                <header>
                    <button name="action_create_de_xuat"
                            string="🛒 Tạo đề xuất mua"
                            type="object"
                            class="oe_highlight"
                            states="done"
                            attrs="{'invisible': [('de_xuat_id', '!=', False)]}"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,done,error"/>
                </header>
                <sheet>
                    <!-- Smart buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-file-text-o"
                                type="object" name="action_create_de_xuat"
                                attrs="{'invisible': ['|', ('state','!=','done'), ('de_xuat_id','!=',False)]}">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Tạo đề xuất</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" icon="fa-check-circle"
                                type="object" name="action_create_de_xuat"
                                attrs="{'invisible': [('de_xuat_id','=',False)]}">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Đã tạo đề xuất</span>
                            </div>
                        </button>
                    </div>

                    <!-- Thông tin hóa đơn -->
                    <group>
                        <group string="📋 Thông tin hóa đơn">
                            <field name="name" string="Tên file"/>
                            <field name="nha_cung_cap" string="Nhà cung cấp"/>
                            <field name="so_hoa_don" string="Số hóa đơn"/>
                            <field name="ngay_hoa_don" string="Ngày hóa đơn"/>
                        </group>
                        <group string="💰 Tài chính">
                            <field name="tong_tien" string="Tổng tiền"/>
                            <field name="thue_vat" string="Thuế VAT"/>
                            <field name="de_xuat_id" string="Đề xuất đã tạo"
                                   attrs="{'invisible': [('de_xuat_id','=',False)]}"/>
                        </group>
                    </group>

                    <!-- Bảng chi tiết hàng hóa trực quan -->
                    <separator string="🛍️ Chi tiết hàng hóa"/>
                    <field name="chi_tiet_html" widget="html" nolabel="1" readonly="1"/>

                    <!-- Thông báo lỗi nếu có -->
                    <div class="alert alert-danger" role="alert"
                         attrs="{'invisible': [('state','!=','error')]}">
                        <strong>❌ Lỗi OCR:</strong>
                        <field name="error_message" nolabel="1" readonly="1"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_invoice_ocr_result" model="ir.actions.act_window">
        <field name="name">Lịch sử OCR hóa đơn</field>
        <field name="res_model">invoice.ocr.result</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Settings -->
    <record id="res_config_settings_view_form_integration" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.integration</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Tích hợp AI &amp; Telegram" string="Tích hợp AI &amp; Telegram">
                    <h2>Tích hợp AI &amp; External API</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="telegram_enabled"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="telegram_enabled"/>
                                <div class="text-muted">Gửi thông báo sự kiện qua Telegram Bot</div>
                                <div class="content-group mt16" attrs="{'invisible': [('telegram_enabled', '=', False)]}">
                                    <field name="telegram_bot_token" password="True" placeholder="Bot Token"/>
                                    <field name="telegram_chat_id" placeholder="Chat ID"/>
                                    <button name="action_test_telegram" type="object" string="Test Telegram" class="btn-link"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="groq_api_key" string="Groq API Key"/>
                                <div class="text-muted">
                                    API Key của Groq – dùng cho AI Chatbot và OCR hóa đơn.
                                    Lấy tại: <a href="https://console.groq.com/keys" target="_blank">console.groq.com/keys</a>
                                </div>
                                <field name="groq_api_key" password="True"
                                       placeholder="gsk_..."/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="auto_post_depreciation"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="auto_post_depreciation"/>
                                <div class="text-muted">Cron khấu hao tự động ghi sổ kế toán</div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
