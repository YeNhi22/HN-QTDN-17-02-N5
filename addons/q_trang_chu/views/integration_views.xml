<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- OCR Wizard -->
    <record id="view_invoice_ocr_wizard_form" model="ir.ui.view">
        <field name="name">invoice.ocr.wizard.form</field>
        <field name="model">invoice.ocr.wizard</field>
        <field name="arch" type="xml">
            <form string="OCR Hóa đơn – Gemini AI">
                <sheet>
                    <!-- Hướng dẫn -->
                    <div class="alert alert-info" role="alert">
                        <strong>📸 Hướng dẫn:</strong> Tải lên ảnh hóa đơn (JPG/PNG),
                        tích xác nhận rồi nhấn <b>Phân tích bằng AI</b>.
                        Mỗi lần phân tích tiêu tốn 1 lượt Gemini API.
                    </div>

                    <group>
                        <!-- Upload file -->
                        <field name="file_data" string="Ảnh hóa đơn (JPG/PNG)"
                               filename="file_name" widget="binary"/>
                        <field name="file_name" invisible="1"/>
                    </group>

                    <!-- Cảnh báo quota – chỉ hiện khi đã chọn file -->
                    <div class="alert alert-warning" role="alert"
                         attrs="{'invisible': [('file_data', '=', False)]}">
                        <strong>⚠️ Lưu ý quota API:</strong>
                        Gemini API miễn phí giới hạn <b>15 lần/phút</b> và <b>1.500 lần/ngày</b>.
                        Chỉ nhấn phân tích khi thực sự cần thiết.
                    </div>

                    <!-- Checkbox xác nhận – bắt buộc tích trước khi gọi API -->
                    <group attrs="{'invisible': [('file_data', '=', False)]}">
                        <field name="ready_to_call"
                               string="✅ Tôi xác nhận muốn gọi Gemini AI để phân tích hóa đơn này"
                               widget="boolean_toggle"/>
                    </group>
                </sheet>
                <footer>
                    <!-- Nút phân tích – chỉ active khi đã tích checkbox -->
                    <button name="action_process_ocr"
                            string="🤖 Phân tích bằng AI"
                            type="object"
                            class="btn-primary"
                            attrs="{'invisible': [('ready_to_call', '=', False)]}"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_invoice_ocr_wizard" model="ir.actions.act_window">
        <field name="name">OCR Hóa đơn (Gemini AI)</field>
        <field name="res_model">invoice.ocr.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- OCR Result -->
    <record id="view_invoice_ocr_result_tree" model="ir.ui.view">
        <field name="name">invoice.ocr.result.tree</field>
        <field name="model">invoice.ocr.result</field>
        <field name="arch" type="xml">
            <tree string="Kết quả OCR">
                <field name="create_date"/>
                <field name="name"/>
                <field name="nha_cung_cap"/>
                <field name="so_hoa_don"/>
                <field name="tong_tien"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_invoice_ocr_result_form" model="ir.ui.view">
        <field name="name">invoice.ocr.result.form</field>
        <field name="model">invoice.ocr.result</field>
        <field name="arch" type="xml">
            <form string="Kết quả OCR hóa đơn">
                <header>
                    <button name="action_create_de_xuat" string="Tạo đề xuất mua" type="object"
                            class="oe_highlight" states="done"
                            attrs="{'invisible': [('de_xuat_id', '!=', False)]}"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="nha_cung_cap"/>
                            <field name="so_hoa_don"/>
                            <field name="ngay_hoa_don"/>
                        </group>
                        <group>
                            <field name="tong_tien"/>
                            <field name="thue_vat"/>
                            <field name="de_xuat_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Chi tiết">
                            <field name="chi_tiet" nolabel="1"/>
                        </page>
                        <page string="JSON thô">
                            <field name="raw_json" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_invoice_ocr_result" model="ir.actions.act_window">
        <field name="name">Lịch sử OCR hóa đơn</field>
        <field name="res_model">invoice.ocr.result</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Settings -->
    <record id="res_config_settings_view_form_integration" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.integration</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Tích hợp AI &amp; Telegram" string="Tích hợp AI &amp; Telegram">
                    <h2>Tích hợp AI &amp; External API (Mức 3)</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="telegram_enabled"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="telegram_enabled"/>
                                <div class="text-muted">Gửi thông báo sự kiện qua Telegram Bot</div>
                                <div class="content-group mt16" attrs="{'invisible': [('telegram_enabled', '=', False)]}">
                                    <field name="telegram_bot_token" password="True" placeholder="Bot Token"/>
                                    <field name="telegram_chat_id" placeholder="Chat ID"/>
                                    <button name="action_test_telegram" type="object" string="Test Telegram" class="btn-link"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="gemini_api_key"/>
                                <div class="text-muted">API key cho Chatbot AI và OCR hóa đơn</div>
                                <field name="gemini_api_key" password="True"/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="auto_post_depreciation"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="auto_post_depreciation"/>
                                <div class="text-muted">Cron khấu hao tự động ghi sổ kế toán (Mức 2)</div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
